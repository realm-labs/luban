{{~end~}}
        val {{item.name}}: {{__name}} = {{__name}}({{item.int_value}})
    {{~end~}}

        fun fromValue(value: Int): {{__name}} = {{__name}}(value)
    }
}
{{~else~}}
enum class {{__name}}(val value: Int) {
    {{~if __this.items.empty?~}}
    ;
    {{~else~}}
    {{~ for item in __this.items ~}}
{{~if item.comment_or_alias != '' ~}}
    /**
