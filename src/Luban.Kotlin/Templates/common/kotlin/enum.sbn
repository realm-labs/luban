{{~if __this.is_flags~}}
@JvmInline
value class {{__name}}(val value: Int) {
    fun has(flag: {{__name}}): Boolean = (value and flag.value) == flag.value

    infix fun or(flag: {{__name}}): {{__name}} = {{__name}}(value or flag.value)

    infix fun and(flag: {{__name}}): {{__name}} = {{__name}}(value and flag.value)

    operator fun plus(flag: {{__name}}): {{__name}} = this or flag

    companion object {
    {{~ for item in __this.items ~}}
{{~if item.comment_or_alias != '' ~}}
        /**
