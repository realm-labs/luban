     */
{{~end~}}
    {{item.name}}({{item.int_value}}){{if for.last}};{{else}},{{end}}
    {{~end~}}
    {{~end~}}

    companion object {
        private val valueMap: Map<Int, {{__name}}> = values().associateBy { it.value }

        fun fromValue(value: Int): {{__name}} {
